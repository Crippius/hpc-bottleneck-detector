# =======================================================================
# XBAT credentials - copy this file to .env and fill in your real values.  
# =======================================================================

# Base URL of your XBAT instance
XBAT_API_BASE=https://demo.xbat.dev

# OAuth credentials
XBAT_USERNAME=demo
XBAT_PASSWORD=demo
XBAT_CLIENT_ID=demo

# Optional: SOCKS5 / HTTP proxy used for requests to XBAT
# Leave empty or remove if no proxy is needed.
XBAT_PROXY=

# Set to 'false' to disable TLS certificate verification.
# Needed for servers with self-signed certificates (e.g. xbat-master).
XBAT_VERIFY_SSL=true
