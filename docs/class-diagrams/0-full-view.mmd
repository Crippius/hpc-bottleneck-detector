classDiagram
    %% ============================================
    %% 1. DATA SOURCE ABSTRACTION
    %% ============================================

    class IDataSource {
        <<interface>>
        +fetch_job_data(job_id: str) DataManager
    }

    class CSVDataSource {
        +file_path: Path
        +delimiter: str
        +__init__(file_path: str, delimiter: str)
        +fetch_job_data(job_id: str) DataManager
        -_read_csv_robust() DataFrame
        -_intra_node_imbalance_row(job_id: str, df: DataFrame)$ Optional~dict~
    }

    class XBATDataSource {
        +api_base: str
        +username: str
        +group: str
        +metric: str
        +level: str
        +node: str
        +session: Session
        +__init__(api_base: str, username: str, password: str, client_id: str, ...)
        +from_env(env_file: str, ...) XBATDataSource$
        +fetch_job_data(job_id: str) DataManager
        -_get_authenticated(url: str) Response
        -_validate_token() bool
        -_request_new_token() None
        -_build_url(job_id: str) str
    }

    IDataSource <|.. CSVDataSource : implements
    IDataSource <|.. XBATDataSource : implements
    IDataSource --> DataManager : creates

    %% ============================================
    %% 2. ORCHESTRATION
    %% ============================================

    class AnalysisOrchestrator {
        +data_source: IDataSource
        +strategy: IAnalysisStrategy
        +window_size: int
        +step_size: int
        +output_cfg: dict
        +__init__(data_source: IDataSource, strategy: IAnalysisStrategy, window_size: int, step_size: int, output_cfg: dict)
        +from_config(config_path: str) AnalysisOrchestrator$
        +run_pipeline(job_id: str) List~WindowDiagnosis~
        -_apply_filters(window_diagnoses: List~WindowDiagnosis~) List~WindowDiagnosis~
        -_build_data_source(cfg: dict)$ IDataSource
        -_build_strategy(cfg: dict)$ IAnalysisStrategy
    }

    AnalysisOrchestrator --> IDataSource : uses
    AnalysisOrchestrator o-- IAnalysisStrategy : strategy
    AnalysisOrchestrator --> DataManager : uses
    AnalysisOrchestrator --> WindowDiagnosis : produces

    %% ============================================
    %% 3. DATA MANAGEMENT
    %% ============================================

    class DataManager {
        +job_data: DataFrame
        +job_id: str
        +job_context: Optional~JobContext~
        +__init__(job_data: DataFrame, job_context: Optional~JobContext~)
        +get_metric(group: str, metric: str, trace: Optional~str~) Series
        +get_metrics(metric_specs: List~dict~) DataFrame
        +list_available_metrics() DataFrame
        +has_metric(group: str, metric: str, trace: Optional~str~) bool
        +get_time_series_length() int
        +get_all_time_series() DataFrame
        +get_flat_dataframe(interval_seconds: int) DataFrame
        +slice_window(start: int, end: int) DataManager
        +iterate_windows(window_size: int, step_size: int) Generator
    }

    class JobContext {
        +job_id: str
        +job_metadata: dict
        +node_hardware: dict
        +__init__(job_id: str, job_metadata: dict, node_hardware: dict)
        +from_xbat(job_id: str, job_entry: dict, node_hardware_raw: dict) JobContext$
        +get_job_id() str
        +get_metadata(key: str, default: Any) Any
        +get_node_hashes() List~str~
        +get_node_info(node_hash: str) Optional~dict~
        +get_benchmark(key: str, aggregate: str) Optional~float~
        +get_cpu_info(key: str) Optional~Any~
        +get_memory_info(key: str) Optional~Any~
    }

    DataManager o-- JobContext : job_context
    XBATDataSource --> JobContext : builds

    %% ============================================
    %% 4. STRATEGY PATTERN
    %% ============================================

    class IAnalysisStrategy {
        <<interface>>
        +diagnose(data_mgr: DataManager) List~Diagnosis~
        +get_required_metrics() List~str~
    }

    class HeuristicStrategy {
        +strategy_folder: Optional~Path~
        -_strategy_trees: List~StrategyTree~
        +__init__(strategy_folder: Optional~str~)
        +diagnose(data_mgr: DataManager) List~Diagnosis~
        +get_required_metrics() List~str~
        -_load_trees(folder: Path) None
    }

    class SupervisedMLStrategy {
        +backend: IMLBackend
        +significance_threshold: float
        +__init__(backend: IMLBackend, significance_threshold: float)
        +diagnose(data_mgr: DataManager) List~Diagnosis~
        +get_required_metrics() List~str~
    }

    IAnalysisStrategy <|.. HeuristicStrategy : implements
    IAnalysisStrategy <|.. SupervisedMLStrategy : implements
    IAnalysisStrategy --> DataManager : uses
    IAnalysisStrategy --> Diagnosis : produces

    %% ============================================
    %% 5. STRATEGY TREE (Heuristic Decision Tree)
    %% ============================================

    class StrategyTree {
        +tree_name: str
        +description: str
        +root_node: PropertyNode
        +config_path: str
        +__init__(tree_name: str, description: str, root_node: PropertyNode, required_metrics: List~dict~, config_path: str)
        +load_from_yaml(path: str) StrategyTree$
        +traverse(data_mgr: DataManager) Diagnosis
        +get_required_metrics() List~dict~
        -_missing_metrics(data_mgr: DataManager) List~str~
    }

    class PropertyNode {
        +node_id: str
        +description: str
        +__init__(config: dict)
        +is_leaf() bool
        +evaluate(data_mgr: DataManager) Tuple~bool, float, float~
        +get_child(branch: bool) PropertyNode
        +get_diagnosis(source: str, triggered_metrics: List~str~, metric_value: float) Diagnosis
    }

    HeuristicStrategy o-- StrategyTree : _strategy_trees
    StrategyTree *-- PropertyNode : root_node
    StrategyTree --> DataManager : uses
    PropertyNode --> PropertyNode : if_true / if_false
    PropertyNode --> DataManager : queries

    %% ============================================
    %% 6. ML COMPONENTS
    %% ============================================

    class IMLBackend {
        <<interface>>
        +train(labelled_csv_paths: List~str~, window_size: int, step_size: int, severity_threshold: float) None
        +predict_probabilities(window_df: DataFrame) dict~str, float~
        +save(path: str) None
        +load(path: str) IMLBackend$
    }

    class DefaultBackend {
        -_classifier: ClassifierMixin
        -_models: dict~str, ClassifierMixin~
        -_feature_cols: dict~str, List~str~~
        -_fc_params: dict
        +__init__(classifier: ClassifierMixin)
        +train(labelled_csv_paths: List~str~, window_size: int, step_size: int, severity_threshold: float) None
        +predict_probabilities(window_df: DataFrame) dict~str, float~
        +save(path: str) None
        +load(path: str) DefaultBackend$
    }

    IMLBackend <|.. DefaultBackend : implements
    SupervisedMLStrategy *-- IMLBackend : backend

    %% ============================================
    %% 7. OUTPUT LAYER
    %% ============================================

    class WindowDiagnosis {
        <<dataclass>>
        +window_index: int
        +start_interval: int
        +end_interval: int
        +diagnoses: List~Diagnosis~
        +has_bottlenecks() bool
        +has_unknowns() bool
        +worst_severity() float
        +to_dict() dict
    }

    class Diagnosis {
        <<dataclass>>
        +bottleneck_type: BottleneckType
        +severity_score: float
        +confidence: float
        +recommendation: Optional~str~
        +source: str
        +triggered_metrics: List~str~
        +is_healthy: bool
        +is_unknown: bool
        +to_dict() dict
    }

    class BottleneckType {
        <<enumeration>>
        PIPELINE_STALL
        COMPUTE_UNDERUTILIZATION
        PRECISION_WASTE
        BRANCH_MISPREDICTION
        CACHE_PRESSURE
        INTRA_NODE_LOAD_IMBALANCE
        INTER_NODE_LOAD_IMBALANCE
        NONE
        UNKNOWN
        +get_macro_category() MacroCategoryType
    }

    class MacroCategoryType {
        <<enumeration>>
        COMPUTE_BOUND
        MEMORY_BOUND
        LOAD_IMBALANCE
        OTHER
        NONE
        UNKNOWN
    }

    WindowDiagnosis *-- Diagnosis : contains
    Diagnosis --> BottleneckType : has
    BottleneckType --> MacroCategoryType : get_macro_category
